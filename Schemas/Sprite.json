{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Hatch sprite",
  "type": "object",
  "properties": {
    "version": {
      "type": "integer"
    },
    "meta": {
      "type": "object",
      "properties": {
        "exporter": {
          "type": "string"
        }
      }
    },
    "spritesheets": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string"
          },
          "type": {
            "type": "string"
          }
        },
        "required": [
          "path",
          "type"
        ]
      }
    },
    "animations": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "speed": {
            "type": "number"
          },
          "loopFrame": {
            "type": "integer"
          },
          "direction": {
            "enum": [
              "forward",
              "reverse",
              "ping-pong",
              "ping-pong-reverse"
            ]
          },
          "rotationStyle": {
            "enum": [
              "none",
              "full",
              "45-degrees",
              "90-degrees",
              "180-degrees",
              "static-frames"
            ]
          },
          "frames": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "sheetX": {
                  "type": "integer"
                },
                "sheetY": {
                  "type": "integer"
                },
                "width": {
                  "type": "integer"
                },
                "height": {
                  "type": "integer"
                },
                "offsetX": {
                  "type": "integer"
                },
                "offsetY": {
                  "type": "integer"
                },
                "duration": {
                  "type": "number"
                },
                "sheetIndex": {
                  "type": "integer"
                },
                "id": {
                  "type": "integer"
                },
                "hitboxes": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "name": {
                        "type": "string"
                      },
                      "left": {
                        "type": "integer"
                      },
                      "top": {
                        "type": "integer"
                      },
                      "right": {
                        "type": "integer"
                      },
                      "bottom": {
                        "type": "integer"
                      }
                    },
                    "required": [
                      "name",
                      "left",
                      "top",
                      "right",
                      "bottom"
                    ]
                  }
                }
              },
              "required": [
                "sheetX",
                "sheetY",
                "width",
                "height"
              ]
            }
          }
        },
        "required": [
          "name",
          "frames"
        ]
      }
    }
  },
  "required": [
    "version",
    "spritesheets",
    "animations"
  ]
}
